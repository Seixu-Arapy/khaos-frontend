# Supabase — find these in your Supabase project settings → API
VITE_SUPABASE_URL=https://clgycvshoqiczgdfxnyi.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
# Used by the Claude chat proxy client (src/lib/chat/client.ts) — must match
# the anthropic-proxy Edge Function's ambient SUPABASE_ANON_KEY, which is the
# new-format publishable key, not the legacy JWT above.
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here


# Claude model the chat agent uses. No key belongs here — the Anthropic API
# key lives server-side only, as a Supabase secret on the anthropic-proxy
# Edge Function (see supabase/functions/anthropic-proxy):
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
VITE_LLM_MODEL=claude-sonnet-5

# Disabled automatically when VITE_APP_PASSWORD_HASH is empty (dev mode).
# To set it up: echo -n "yourpassword" | sha256sum
VITE_APP_PASSWORD_HASH=

# Dev server runs over HTTPS by default (locally-trusted cert via mkcert).
# Set to "false" to run plain HTTP instead.
VITE_USE_HTTPS=


# ---------------------------------------------------------------------------
# Telegram bot (supabase/functions/telegram-bot)
# ---------------------------------------------------------------------------
# These are NOT Vite vars — they live server-side as Supabase function secrets,
# never in this .env. Set them with `supabase secrets set NAME=value`:
#   TELEGRAM_BOT_TOKEN         from @BotFather
#   TELEGRAM_WEBHOOK_SECRET    random string; also passed as secret_token to setWebhook
#   TELEGRAM_ALLOWED_CHAT_IDS  comma-separated numeric chat ids allowed to use the bot
#   LLM_MODEL                  (optional) model the bot uses; defaults to claude-sonnet-5
#   TELEGRAM_TIMEZONE          (optional) IANA tz for temporal context; defaults to America/Sao_Paulo
# ANTHROPIC_API_KEY is shared with the anthropic-proxy function and only needs
# to be set once. See the function's file header for the full deploy steps.