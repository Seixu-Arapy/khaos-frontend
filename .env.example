# Supabase — find these in your Supabase project settings → API
VITE_SUPABASE_URL=https://clgycvshoqiczgdfxnyi.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here


# Groq – get a key https://console.groq.com
VITE_GROQ_API_KEY=
# Groq – available models at https://console.groq.com/docs/models
VITE_LLM_MODEL=llama-3.1-70b-versatile

# Disabled automatically when VITE_APP_PASSWORD_HASH is empty (dev mode).
# To set it up: echo -n "yourpassword" | sha256sum
VITE_APP_PASSWORD_HASH=

# Dev server runs over HTTPS by default (locally-trusted cert via mkcert).
# Set to "false" to run plain HTTP instead.
VITE_USE_HTTPS=